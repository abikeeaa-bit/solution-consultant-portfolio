  },
  "item": [
    {
      "name": "POST - Valid chat message",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function() {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Response time under 30 seconds\", function() {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(30000);\r",
              "});\r",
              "pm.test(\"Response contains AI message\", function() {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.have.property('choices');\r",
              "    pm.expect(json.choices[0]).to.have.property('message');\r",
              "    pm.expect(json.choices[0].message).to.have.property('content');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{hf_token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"model\": \"meta-llama/Llama-3.2-3B-Instruct:cerebras\",\r\n  \"messages\": [\r\n    {\r\n      \"role\": \"user\",\r\n      \"content\": \"My kitchen tap is leaking. Can you log a maintenance request?\"\r\n    }\r\n  ],\r\n  \"max_tokens\": 100\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://router.huggingface.co/v1/chat/completions",
          "protocol": "https",
          "host": [
            "router",
            "huggingface",
            "co"
          ],
          "path": [
            "v1",
            "chat",
            "completions"
          ]
        }
      },
      "response": []
    },
